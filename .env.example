# Required
DATABASE_URL=postgres://bot:bot@localhost:5432/polymarket
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# OpenRouter API key (sk-or-v1-...). Used for chat/completion AND embeddings,
# both routed through https://openrouter.ai/api/v1. Legacy name OPENAI_API_KEY
# still works as a fallback if OPENROUTER_API_KEY is unset.
OPENROUTER_API_KEY=your_openrouter_api_key

# Optional (defaults shown)
# LLM_MODELS=openai/gpt-oss-120b:free,nvidia/nemotron-3-super-120b-a12b:free,google/gemma-4-31b-it:free,openai/gpt-oss-20b:free
#   ^ CSV rotation list for chat/completion (consensus agents + correlation check).
#     On failure, the next model is tried. Set to "" to fall back to LLM_MODEL.
#     Note: OpenRouter's free-tier daily cap (50/day, or 1000/day with >=$10
#     lifetime credit) is ACCOUNT-WIDE across all :free models combined, not
#     per-model — rotation buys failover/resilience, not extra quota.
#     Embeddings are NOT part of this rotation; they stay pinned to
#     text-embedding-3-small (no free embeddings tier on OpenRouter).
# SCAN_INTERVAL_MINS=30
# NEWS_SCAN_INTERVAL_MINS=10
# NEWS_ENABLED=false
# SLIPPAGE_PCT=0.01
# FEE_PCT=0.02
# MIN_VOLUME=1000.0
# MIN_BOOK_DEPTH=200.0
# KELLY_FRACTION=0.25
# MAX_DAYS_TO_EXPIRY=14
# MAX_LLM_CANDIDATES=1
# MAX_MODEL_CANDIDATES=15
# MIN_EFFECTIVE_EDGE=0.08
# LLM_MODEL=gpt-4o
# HEARTBEAT_INTERVAL_MINS=60
# CONSENSUS_AGENTS=2
# CALIBRATION_MIN_SAMPLES=20
# MAX_MARKETS_FETCH=1000
# MIN_PRICE=0.03
# MAX_PRICE=0.97
# STRATEGY_BANKROLL=300.0
# STRATEGIES=aggressive,balanced,conservative
#
# --- Per-strategy tuning (override any individual param) ---
# AGGRESSIVE_KELLY_FRACTION=0.50
# AGGRESSIVE_MIN_EDGE=0.05
# AGGRESSIVE_MIN_CONFIDENCE=0.40
# AGGRESSIVE_MAX_SIGNALS=10
# AGGRESSIVE_MIN_BET=5.0
#
# BALANCED_KELLY_FRACTION=0.25
# BALANCED_MIN_EDGE=0.06
# BALANCED_MIN_CONFIDENCE=0.40
# BALANCED_MAX_SIGNALS=5
# BALANCED_MIN_BET=5.0
#
# CONSERVATIVE_KELLY_FRACTION=0.15
# CONSERVATIVE_MIN_EDGE=0.08
# CONSERVATIVE_MIN_CONFIDENCE=0.50
# CONSERVATIVE_MAX_SIGNALS=3
# CONSERVATIVE_MIN_BET=15.0
# STOP_LOSS_PCT=999.0
# EXIT_DAYS_BEFORE_EXPIRY=0
# MODEL_SIDECAR_URL=
# COPY_TRADE_ENABLED=false
# COPY_TRADE_INTERVAL_MINS=5
#
# --- HTTP/sidecar timeouts (trading-bot) ---
# SIDECAR_TIMEOUT_SECS=10
# SIDECAR_MAX_RETRIES=3
# SIDECAR_RETRY_DELAY_SECS=2
# HTTP_TIMEOUT_SECS=30
# NEWS_FETCH_TIMEOUT_SECS=15
#
# --- WS alert loop (trading-bot) ---
# ALERT_THROTTLE_MINS=15
# WS_BET_COOLDOWN_SECS=600
# PRICE_ALERT_COOLDOWN_SECS=3600
# MAX_WS_BETS_PER_DAY=3
# WS_RECONNECT_DELAY_SECS=5
# WS_MIN_PRICE_DELTA=0.03
# WS_MIN_TRADE_USD=500.0
#
# --- Copy-trading-bot specific (separate process/env from above) ---
# COPY_DATA_API_URL=https://data-api.polymarket.com
# COPY_GAMMA_API_URL=https://gamma-api.polymarket.com
# COPY_REQUEST_TIMEOUT_SECS=15
# COPY_LEADERBOARD_SECTION_LIMIT=5
# COPY_STALE_TRADE_SECS=300
# COPY_STARTING_BANKROLL=1000.0
# COPY_KELLY_FRACTION=0.25
# COPY_MIN_BET=3.0
# COPY_MAX_PRICE_DRIFT=0.05
# COPY_HOUSEKEEPING_INTERVAL_MINS=5
# COPY_TELEGRAM_POLL_SECS=3
# COPY_DB_RETRY_DELAY_SECS=3

RUST_LOG=info
